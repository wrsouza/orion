{
  "name": "@wrsouza/orion",
  "version": "0.4.2",
  "description": "Eloquent-inspired Active Record ORM for TypeScript — PostgreSQL, MySQL, MariaDB, SQLite, SQL Server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "orion": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "orion",
    "orm",
    "active-record",
    "eloquent",
    "typescript",
    "postgres",
    "postgresql",
    "mysql",
    "mariadb",
    "sqlite",
    "sqlserver",
    "database",
    "query-builder",
    "migrations",
    "seeds",
    "seeders",
    "factories",
    "decorators"
  ],
  "author": {
    "name": "wrsouza",
    "url": "https://github.com/wrsouza"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wrsouza/orion.git"
  },
  "homepage": "https://wrsouza.github.io/orion/",
  "bugs": {
    "url": "https://github.com/wrsouza/orion/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "mysql2": ">=3.0.0",
    "mariadb": ">=3.0.0",
    "better-sqlite3": ">=9.0.0",
    "mssql": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "mariadb": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "mssql": {
      "optional": true
    }
  }
}
